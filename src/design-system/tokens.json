{
  "$schema": "https://design-tokens.org/schema.json",
  "$description": "Zenvi Design System — Space Edition v1.0. Dark-mode first. WCAG 2.1 AA compliant.",

  "color": {
    "$description": "Complete Zenvi color system. All semantic tokens reference primitive values.",

    "primitive": {
      "plasma": {
        "$description": "Electric blue — brand primary (#0066FF anchor)",
        "50":  { "$value": "#E0EEFF", "$type": "color" },
        "100": { "$value": "#BAD6FF", "$type": "color" },
        "200": { "$value": "#80AAFF", "$type": "color" },
        "300": { "$value": "#4D88FF", "$type": "color", "$description": "AAA text on #0a0a0f (7.1:1)" },
        "400": { "$value": "#1A66FF", "$type": "color" },
        "500": { "$value": "#0066FF", "$type": "color", "$description": "Brand primary anchor" },
        "600": { "$value": "#0052CC", "$type": "color" },
        "700": { "$value": "#003D99", "$type": "color" },
        "800": { "$value": "#002966", "$type": "color" },
        "900": { "$value": "#001433", "$type": "color" },
        "950": { "$value": "#000A1A", "$type": "color" }
      },
      "nebula": {
        "$description": "Cosmic purple — brand secondary, decorative gradients",
        "50":  { "$value": "#F3E8FF", "$type": "color" },
        "100": { "$value": "#E0C8FF", "$type": "color" },
        "200": { "$value": "#C898FF", "$type": "color" },
        "300": { "$value": "#A855F7", "$type": "color", "$description": "Nebula on dark, AAA text" },
        "400": { "$value": "#8B35E8", "$type": "color" },
        "500": { "$value": "#6E18D4", "$type": "color" },
        "600": { "$value": "#5510A8", "$type": "color" },
        "700": { "$value": "#3D0880", "$type": "color" },
        "800": { "$value": "#280558", "$type": "color" },
        "900": { "$value": "#160230", "$type": "color" },
        "950": { "$value": "#0A0118", "$type": "color" }
      },
      "aurora": {
        "$description": "Cyan-green — success states, positive data flow",
        "50":  { "$value": "#E0FFF8", "$type": "color" },
        "100": { "$value": "#B3FFEC", "$type": "color" },
        "200": { "$value": "#66FFD6", "$type": "color" },
        "300": { "$value": "#1AFFBE", "$type": "color", "$description": "Success text — 11.4:1 AAA on #0a0a0f" },
        "400": { "$value": "#00D99E", "$type": "color" },
        "500": { "$value": "#00B380", "$type": "color" },
        "600": { "$value": "#008C63", "$type": "color" },
        "700": { "$value": "#006647", "$type": "color" },
        "800": { "$value": "#00402C", "$type": "color" },
        "900": { "$value": "#001A12", "$type": "color" },
        "950": { "$value": "#000D09", "$type": "color" }
      },
      "stellar": {
        "$description": "Warm gold — premium/featured states, warning",
        "50":  { "$value": "#FFFDF0", "$type": "color" },
        "100": { "$value": "#FFF8D6", "$type": "color" },
        "200": { "$value": "#FFEEAA", "$type": "color" },
        "300": { "$value": "#FFE066", "$type": "color" },
        "400": { "$value": "#FFD01A", "$type": "color" },
        "500": { "$value": "#F5C000", "$type": "color" },
        "600": { "$value": "#C29400", "$type": "color" },
        "700": { "$value": "#8F6A00", "$type": "color" },
        "800": { "$value": "#5C4200", "$type": "color" },
        "900": { "$value": "#291E00", "$type": "color" },
        "950": { "$value": "#140F00", "$type": "color" }
      },
      "infrared": {
        "$description": "Warm red — error/destructive states",
        "50":  { "$value": "#FFF0F0", "$type": "color" },
        "100": { "$value": "#FFD6D6", "$type": "color" },
        "200": { "$value": "#FFAAAA", "$type": "color" },
        "300": { "$value": "#FF7070", "$type": "color", "$description": "Error text — 5.9:1 AA on #0a0a0f" },
        "400": { "$value": "#FF3838", "$type": "color" },
        "500": { "$value": "#E81818", "$type": "color" },
        "600": { "$value": "#C00808", "$type": "color" },
        "700": { "$value": "#900000", "$type": "color" },
        "800": { "$value": "#600000", "$type": "color" },
        "900": { "$value": "#300000", "$type": "color" },
        "950": { "$value": "#180000", "$type": "color" }
      },
      "space": {
        "$description": "Cold blue-tinted neutrals — primary UI chrome",
        "50":  { "$value": "#F0F0FF", "$type": "color", "$description": "Primary text — 14.2:1 AAA on #0a0a0f" },
        "100": { "$value": "#D8D8F0", "$type": "color" },
        "200": { "$value": "#B8B8D8", "$type": "color" },
        "300": { "$value": "#9898C0", "$type": "color", "$description": "Secondary text — 6.3:1 AA" },
        "400": { "$value": "#6868A0", "$type": "color" },
        "500": { "$value": "#484880", "$type": "color" },
        "600": { "$value": "#303060", "$type": "color" },
        "700": { "$value": "#1E1E48", "$type": "color" },
        "800": { "$value": "#12122E", "$type": "color" },
        "900": { "$value": "#0A0A1E", "$type": "color" },
        "950": { "$value": "#050510", "$type": "color", "$description": "Deepest void — page canvas" }
      },
      "void": {
        "$description": "Pure blacks — deepest backgrounds",
        "700": { "$value": "#141420", "$type": "color", "$description": "Surface raised" },
        "800": { "$value": "#0C0C18", "$type": "color" },
        "900": { "$value": "#060610", "$type": "color" },
        "950": { "$value": "#020208", "$type": "color" }
      },
      "stardust": {
        "$description": "Muted grays — secondary UI chrome",
        "300": { "$value": "#BEBECE", "$type": "color" },
        "400": { "$value": "#9A9AAE", "$type": "color" },
        "500": { "$value": "#78788E", "$type": "color" },
        "700": { "$value": "#3A3A4E", "$type": "color" },
        "900": { "$value": "#101018", "$type": "color" }
      },
      "ion": {
        "$description": "Teal — highlight accents, ion-400 is brand accent",
        "400": { "$value": "#00D9C8", "$type": "color" },
        "500": { "$value": "#00B3A8", "$type": "color" }
      }
    },

    "semantic": {
      "$description": "Semantic tokens reference primitives. Dark mode is the primary mode.",

      "bg": {
        "primary":   { "$value": "#0a0a0f", "$type": "color", "$description": "Page canvas — use on body" },
        "secondary": { "$value": "#0c0c1a", "$type": "color", "$description": "Nested section backgrounds" },
        "tertiary":  { "$value": "#101018", "$type": "color", "$description": "Sunken areas, code blocks" },
        "inverse":   { "$value": "#f0f0ff", "$type": "color", "$description": "Inverted surfaces (rare)" }
      },
      "surface": {
        "raised":   { "$value": "#141420", "$type": "color", "$description": "Elevated surfaces — cards, panels" },
        "overlay":  { "$value": "rgba(20,20,32,0.92)", "$type": "color", "$description": "Modal/drawer background" },
        "sunken":   { "$value": "#060610",              "$type": "color", "$description": "Depressed — code blocks" }
      },
      "text": {
        "primary":   { "$value": "#f0f0ff", "$type": "color", "$description": "14.2:1 contrast — AAA" },
        "secondary": { "$value": "#9898c0", "$type": "color", "$description": "6.3:1 contrast — AA" },
        "disabled":  { "$value": "#484880", "$type": "color", "$description": "2.8:1 — informational only, always pair with non-color indicator" },
        "inverse":   { "$value": "#050510", "$type": "color" },
        "link":      { "$value": "#4d88ff", "$type": "color", "$description": "7.1:1 — AAA" },
        "error":     { "$value": "#ff7070", "$type": "color", "$description": "5.9:1 — AA" },
        "success":   { "$value": "#1affbe", "$type": "color", "$description": "11.4:1 — AAA" }
      },
      "border": {
        "subtle":  { "$value": "rgba(255,255,255,0.06)", "$type": "color" },
        "default": { "$value": "rgba(255,255,255,0.10)", "$type": "color" },
        "strong":  { "$value": "rgba(255,255,255,0.20)", "$type": "color" }
      },
      "interactive": {
        "primary":        { "$value": "#0066ff", "$type": "color" },
        "primary-hover":  { "$value": "#1a66ff", "$type": "color" },
        "primary-active": { "$value": "#0052cc", "$type": "color" },
        "secondary":      { "$value": "#1e1e48", "$type": "color" },
        "disabled":       { "$value": "#1e1e48", "$type": "color" }
      },
      "feedback": {
        "success":        { "$value": "#00b380", "$type": "color" },
        "success-subtle": { "$value": "rgba(0,179,128,0.12)", "$type": "color" },
        "success-strong": { "$value": "#1affbe", "$type": "color" },
        "warning":        { "$value": "#f5c000", "$type": "color" },
        "warning-subtle": { "$value": "rgba(245,192,0,0.12)", "$type": "color" },
        "warning-strong": { "$value": "#ffe066", "$type": "color" },
        "error":          { "$value": "#e81818", "$type": "color" },
        "error-subtle":   { "$value": "rgba(232,24,24,0.12)", "$type": "color" },
        "error-strong":   { "$value": "#ff7070", "$type": "color" },
        "info":           { "$value": "#0066ff", "$type": "color" },
        "info-subtle":    { "$value": "rgba(0,102,255,0.12)", "$type": "color" },
        "info-strong":    { "$value": "#80aaff", "$type": "color" }
      },
      "brand": {
        "primary":   { "$value": "#0066ff", "$type": "color", "$description": "plasma-500" },
        "secondary": { "$value": "#a855f7", "$type": "color", "$description": "nebula-300 — used in dark" },
        "accent":    { "$value": "#00d9c8", "$type": "color", "$description": "ion-400" }
      }
    }
  },

  "typography": {
    "fontFamily": {
      "primary": {
        "$value": "Inter, system-ui, -apple-system, BlinkMacSystemFont, Segoe UI, sans-serif",
        "$type": "fontFamily",
        "$description": "Primary UI typeface — geometric humanist, extreme legibility"
      },
      "mono": {
        "$value": "JetBrains Mono, Fira Code, SF Mono, Consolas, monospace",
        "$type": "fontFamily",
        "$description": "Code, timestamps, technical values"
      }
    },
    "scale": {
      "display-xl": {
        "size":          { "$value": "clamp(40px, 6.5vw, 72px)", "$type": "dimension" },
        "lineHeight":    { "$value": "1.05", "$type": "number" },
        "weight":        { "$value": "700", "$type": "fontWeight" },
        "letterSpacing": { "$value": "-0.03em", "$type": "dimension" },
        "$description": "Hero headline. Mobile: 40px, Desktop: 72px"
      },
      "display-l": {
        "size":          { "$value": "clamp(32px, 5vw, 56px)", "$type": "dimension" },
        "lineHeight":    { "$value": "1.08", "$type": "number" },
        "weight":        { "$value": "700", "$type": "fontWeight" },
        "letterSpacing": { "$value": "-0.025em", "$type": "dimension" }
      },
      "h1": {
        "size":          { "$value": "clamp(28px, 4.2vw, 48px)", "$type": "dimension" },
        "lineHeight":    { "$value": "1.1", "$type": "number" },
        "weight":        { "$value": "600", "$type": "fontWeight" },
        "letterSpacing": { "$value": "-0.02em", "$type": "dimension" }
      },
      "h2": {
        "size":          { "$value": "clamp(24px, 3.2vw, 36px)", "$type": "dimension" },
        "lineHeight":    { "$value": "1.15", "$type": "number" },
        "weight":        { "$value": "600", "$type": "fontWeight" },
        "letterSpacing": { "$value": "-0.015em", "$type": "dimension" }
      },
      "h3": {
        "size":          { "$value": "clamp(20px, 2.2vw, 24px)", "$type": "dimension" },
        "lineHeight":    { "$value": "1.2", "$type": "number" },
        "weight":        { "$value": "600", "$type": "fontWeight" },
        "letterSpacing": { "$value": "-0.01em", "$type": "dimension" }
      },
      "h4": {
        "size":          { "$value": "clamp(18px, 1.8vw, 20px)", "$type": "dimension" },
        "lineHeight":    { "$value": "1.25", "$type": "number" },
        "weight":        { "$value": "500", "$type": "fontWeight" },
        "letterSpacing": { "$value": "-0.005em", "$type": "dimension" }
      },
      "body-l": {
        "size":       { "$value": "clamp(16px, 1.6vw, 18px)", "$type": "dimension" },
        "lineHeight": { "$value": "1.6", "$type": "number" },
        "weight":     { "$value": "400", "$type": "fontWeight" },
        "$description": "Large body copy — hero subheadings, feature descriptions"
      },
      "body-m": {
        "size":       { "$value": "16px", "$type": "dimension" },
        "lineHeight": { "$value": "1.6", "$type": "number" },
        "weight":     { "$value": "400", "$type": "fontWeight" },
        "$description": "Standard body copy — minimum for all readable content"
      },
      "body-s": {
        "size":          { "$value": "14px", "$type": "dimension" },
        "lineHeight":    { "$value": "1.55", "$type": "number" },
        "weight":        { "$value": "400", "$type": "fontWeight" },
        "letterSpacing": { "$value": "0.01em", "$type": "dimension" },
        "$description": "Small labels, captions, badge text — minimum 14px"
      },
      "caption": {
        "size":          { "$value": "12px", "$type": "dimension" },
        "lineHeight":    { "$value": "1.5", "$type": "number" },
        "weight":        { "$value": "400", "$type": "fontWeight" },
        "letterSpacing": { "$value": "0.02em", "$type": "dimension" },
        "$description": "Metadata, timestamps — absolute minimum. Must maintain 4.5:1 contrast."
      }
    }
  },

  "spacing": {
    "$description": "Base unit: 8px. All values are named multiples.",
    "0_5": { "$value": "2px",   "$type": "dimension", "$description": "Micro-adjustments, icon offsets" },
    "1":   { "$value": "4px",   "$type": "dimension", "$description": "Icon-to-label gap, chip inner padding" },
    "2":   { "$value": "8px",   "$type": "dimension", "$description": "Button padding Y, small gaps" },
    "3":   { "$value": "12px",  "$type": "dimension", "$description": "Input padding, list item gaps" },
    "4":   { "$value": "16px",  "$type": "dimension", "$description": "Standard component padding" },
    "6":   { "$value": "24px",  "$type": "dimension", "$description": "Card padding, inter-component gap" },
    "8":   { "$value": "32px",  "$type": "dimension", "$description": "Sub-section spacing" },
    "10":  { "$value": "40px",  "$type": "dimension", "$description": "Large card/modal padding" },
    "12":  { "$value": "48px",  "$type": "dimension", "$description": "Between section blocks" },
    "16":  { "$value": "64px",  "$type": "dimension", "$description": "Section padding mobile" },
    "20":  { "$value": "80px",  "$type": "dimension", "$description": "Section padding tablet" },
    "24":  { "$value": "96px",  "$type": "dimension", "$description": "Section padding desktop" },
    "32":  { "$value": "128px", "$type": "dimension", "$description": "Hero section padding" }
  },

  "borderRadius": {
    "none": { "$value": "0px",    "$type": "dimension", "$description": "Full-bleed elements" },
    "sm":   { "$value": "4px",    "$type": "dimension", "$description": "Badges, chips, code blocks" },
    "md":   { "$value": "8px",    "$type": "dimension", "$description": "Buttons, inputs, form controls" },
    "lg":   { "$value": "12px",   "$type": "dimension", "$description": "Standard cards, dropdowns, panels" },
    "xl":   { "$value": "16px",   "$type": "dimension", "$description": "Large cards, modals" },
    "2xl":  { "$value": "24px",   "$type": "dimension", "$description": "Hero cards, showcase panels" },
    "full": { "$value": "9999px", "$type": "dimension", "$description": "Avatars, pills, toggles, FABs" }
  },

  "shadow": {
    "elevation-0": {
      "$value": "none",
      "$type": "shadow",
      "$description": "Flat — canvas and body backgrounds"
    },
    "elevation-1": {
      "$value": "0 1px 3px rgba(0,0,0,0.4), 0 0 0 1px rgba(255,255,255,0.04)",
      "$type": "shadow",
      "$description": "Cards at rest, form inputs"
    },
    "elevation-2": {
      "$value": "0 4px 16px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,255,255,0.06)",
      "$type": "shadow",
      "$description": "Dropdown menus, tooltips, floating elements"
    },
    "elevation-3": {
      "$value": "0 8px 32px rgba(0,0,0,0.6), 0 0 0 1px rgba(255,255,255,0.08)",
      "$type": "shadow",
      "$description": "Modals, drawers, overlaid content"
    },
    "glow-plasma": {
      "$value": "0 0 0 1px rgba(0,102,255,0.3), 0 0 20px rgba(0,102,255,0.2), 0 0 60px rgba(0,102,255,0.1)",
      "$type": "shadow",
      "$description": "Focus ring / active state — primary plasma glow"
    },
    "glow-plasma-sm": {
      "$value": "0 0 0 1px rgba(0,102,255,0.25), 0 0 12px rgba(0,102,255,0.2)",
      "$type": "shadow",
      "$description": "Subtle plasma glow for hover states"
    },
    "glow-plasma-lg": {
      "$value": "0 0 0 1px rgba(0,102,255,0.4), 0 0 32px rgba(0,102,255,0.3), 0 0 80px rgba(0,102,255,0.15)",
      "$type": "shadow",
      "$description": "Strong plasma glow for featured CTA"
    },
    "glow-nebula": {
      "$value": "0 0 0 1px rgba(168,85,247,0.3), 0 0 20px rgba(168,85,247,0.2), 0 0 60px rgba(168,85,247,0.08)",
      "$type": "shadow",
      "$description": "Featured pricing card, special callouts"
    },
    "glow-aurora": {
      "$value": "0 0 0 1px rgba(0,179,128,0.3), 0 0 20px rgba(0,179,128,0.15)",
      "$type": "shadow",
      "$description": "Success states, aurora-themed elements"
    },
    "glow-infrared": {
      "$value": "0 0 0 1px rgba(232,24,24,0.3), 0 0 20px rgba(232,24,24,0.15)",
      "$type": "shadow",
      "$description": "Error states, destructive actions"
    }
  },

  "motion": {
    "duration": {
      "instant": { "$value": "0ms",     "$type": "duration", "$description": "Immediate state changes — no animation" },
      "fast":    { "$value": "150ms",   "$type": "duration", "$description": "Hover states, tooltips, micro-interactions" },
      "normal":  { "$value": "250ms",   "$type": "duration", "$description": "Modal enter/exit, dropdown, drawer" },
      "slow":    { "$value": "400ms",   "$type": "duration", "$description": "Page transitions, large component mount" },
      "slower":  { "$value": "600ms",   "$type": "duration", "$description": "Hero entrance, staggered feature cards" },
      "orbital": { "$value": "8000ms",  "$type": "duration", "$description": "Star field drift — ambient only" },
      "aurora":  { "$value": "12000ms", "$type": "duration", "$description": "Aurora color cycle — ambient only" }
    },
    "easing": {
      "ease-out-expo": {
        "$value": "cubic-bezier(0.16, 1, 0.3, 1)",
        "$type": "cubicBezier",
        "$description": "UI entering — fast start, settles gracefully. Primary for enter animations."
      },
      "ease-in-expo": {
        "$value": "cubic-bezier(0.7, 0, 0.84, 0)",
        "$type": "cubicBezier",
        "$description": "UI exiting — slow start, sharp end."
      },
      "ease-in-out-quart": {
        "$value": "cubic-bezier(0.77, 0, 0.175, 1)",
        "$type": "cubicBezier",
        "$description": "Expanding/collapsing panels, smooth scroll."
      },
      "spring": {
        "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)",
        "$type": "cubicBezier",
        "$description": "Interactive feedback — slight overshoot. Button press, card hover."
      },
      "cosmic": {
        "$value": "cubic-bezier(0.25, 0.46, 0.45, 0.94)",
        "$type": "cubicBezier",
        "$description": "Ambient background animations — slow, organic drifts."
      }
    },
    "principles": {
      "ambient-opacity": {
        "$value": "0.3–0.6",
        "$type": "dimension",
        "$description": "All ambient animations (stars, nebula, aurora) must run at reduced opacity and never compete with interactive feedback during task completion."
      },
      "interactive-range": {
        "$value": "150ms–400ms",
        "$type": "duration",
        "$description": "All interactive feedback must occur within this range. Below 150ms feels instant. Above 400ms feels slow."
      },
      "prefers-reduced-motion": {
        "$value": "required",
        "$type": "other",
        "$description": "All ambient animations must be wrapped in @media (prefers-reduced-motion: reduce). Interactive state changes retain instant color/opacity changes without animation."
      }
    }
  }
}
